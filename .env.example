# Database
# Direct connection (para migrations locais)
DIRECT_URL="postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres"
# Pooling connection (para produção/serverless)
DATABASE_URL="postgresql://postgres:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# App
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
