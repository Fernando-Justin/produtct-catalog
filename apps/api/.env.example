# Database - PostgreSQL
# Local/Docker: postgresql://admin:admin123@localhost:5432/product_catalog-db
# VM/Server: postgresql://admin:admin123@SEU_IP:5432/product_catalog-db
DATABASE_URL="postgresql://admin:admin123@localhost:5432/product_catalog-db"
DIRECT_URL="postgresql://admin:admin123@localhost:5432/product_catalog-db"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# App
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
