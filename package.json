{
  "name": "product-catalog",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:pull": "cd apps/api && npx prisma db pull && npx prisma generate",
    "db:generate": "cd apps/api && npx prisma generate",
    "db:seed": "cd apps/api && npx ts-node src/prisma/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
